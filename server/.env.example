# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# SECURITY: Change default password in production
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/aappr

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication
# CRITICAL: Generate a strong secret (minimum 32 characters)
# Example command: openssl rand -base64 32
# SECURITY: Never use the placeholder value in production
JWT_SECRET=your_jwt_secret_minimum_32_characters_required_change_this_in_production

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend URL (for development)
CLIENT_URL=http://localhost:5173

# Honeybadger Error Monitoring (PRODUCTION ONLY)
# REQUIRED in production — startup will fail without a valid API key.
# Not enforced in development/test environments.
# Get your API key from https://app.honeybadger.io/
HONEYBADGER_API_KEY=your_honeybadger_api_key_here

# Honeybadger Health Authentication Header
# Optional: dedicated shared secret accepted via Honeybadger-Token header for detailed GET /api/v1/health diagnostics.
# Keep this distinct from HONEYBADGER_API_KEY.
HONEYBADGER_AUTH_HEADER=your_dedicated_honeybadger_health_auth_secret_here

# Admin API Key
# REQUIRED in production — used by GET /api/v1/events/export and GET /api/v1/admin/stats via X-API-KEY header.
# Use a long random secret and never expose it to frontend clients.
ADMIN_API_KEY=your_admin_api_key_here

# Optional: set to a git SHA or release tag for deploy correlation in Honeybadger
# APP_REVISION=

# Notion Admin Stats Export (script: npm run admin-stats:export:notion)
# Create an internal integration and set NOTION_API_TOKEN.
# Share both databases with the integration.
NOTION_API_TOKEN=secret_your_notion_integration_token_here
NOTION_PLATFORM_STATS_DATABASE_ID=your_platform_database_id
NOTION_TEAM_STATS_DATABASE_ID=your_team_database_id

# Optional window configuration for the export script (CLI args).
# npm run admin-stats:export:notion -- --label last_30_days
# npm run admin-stats:export:notion -- --from 2026-01-01T00:00:00.000Z --to 2026-01-31T23:59:59.999Z
