# Instance: elia (Story 7.4 contract template)
# Active profile now lives at deploy/compose/elia.env.
# Keep this file as a contract reference and onboarding template.
# Resources: network=aapr-elia-net, volume=aapr-elia-postgres-data, db=aapr_elia
#
# This profile follows the same isolation contract as stu/hms.
# No compose redesign is needed - only env values differ.
INSTANCE_KEY=elia
COMPOSE_PROJECT_NAME=aapr-elia

BACKEND_IMAGE=aapr-backend:7.1
FRONTEND_IMAGE=aapr-frontend:7.1
POSTGRES_IMAGE=postgres:14

FRONTEND_HOST_PORT=5175
BACKEND_HOST_PORT=3002
POSTGRES_HOST_PORT=5545

POSTGRES_DB=aapr_elia
POSTGRES_USER=aapr_user
# REQUIRED: non-empty value. Use a unique, strong password in production.
POSTGRES_PASSWORD=replace-with-strong-password
# REQUIRED: non-empty value. Use a unique, strong secret in production.
JWT_SECRET=replace-with-strong-secret

FRONTEND_RUNTIME_API_URL=http://localhost:5175
