# Story 7.3 instance environment contract
# Copy to deploy/compose/<instance>.env and customize ALL values below.
#
# ISOLATION RULES (Story 7.3):
# - COMPOSE_PROJECT_NAME must be globally unique per instance (e.g., aapr-stu, aapr-hms, aapr-elia)
# - INSTANCE_KEY must match the suffix used in COMPOSE_PROJECT_NAME
# - POSTGRES_DB must be unique per instance to ensure data isolation
# - Host ports (FRONTEND_HOST_PORT, BACKEND_HOST_PORT, POSTGRES_HOST_PORT) must not overlap across instances
# - JWT_SECRET must be unique per instance in production (shared only acceptable for local dev)
# - POSTGRES_PASSWORD should be unique per instance in production
#
# Naming conventions enforced by compose:
#   network:    <COMPOSE_PROJECT_NAME>-net
#   volume:     <COMPOSE_PROJECT_NAME>-postgres-data
#   containers: <COMPOSE_PROJECT_NAME>-<service>
#   database:   <POSTGRES_DB>

# Deterministic instance identity
INSTANCE_KEY=stu
COMPOSE_PROJECT_NAME=aapr-stu

# Image contracts from Story 7.1
BACKEND_IMAGE=aapr-backend:7.1
FRONTEND_IMAGE=aapr-frontend:7.1
POSTGRES_IMAGE=postgres:14

# Host port contracts (must be integer 1-65535 and unique per instance)
# Recommended port ranges per instance:
#   stu:  frontend=5173, backend=3000, postgres=5543
#   hms:  frontend=5174, backend=3001, postgres=5544
#   elia: frontend=5175, backend=3002, postgres=5545
FRONTEND_HOST_PORT=5173
BACKEND_HOST_PORT=3000
POSTGRES_HOST_PORT=5543

# Per-instance database naming and credentials
# POSTGRES_DB MUST be unique per instance (e.g., aapr_stu, aapr_hms, aapr_elia)
POSTGRES_DB=aapr_stu
POSTGRES_USER=aapr_user
# WARNING: Use a unique, strong password per instance in production
POSTGRES_PASSWORD=replace-with-strong-password

# Required by backend runtime validation in production
# Must be non-empty. Use a unique, strong secret per instance.
JWT_SECRET=replace-with-strong-secret

# Frontend runtime API URL consumed by runtime-config.js
# For local host access, point to backend host port of this same instance.
FRONTEND_RUNTIME_API_URL=http://localhost:3000
