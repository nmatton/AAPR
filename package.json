{
  "name": "bmad_version",
  "version": "1.0.0",
  "description": "Research-grade web application for systematic identification and resolution of agile practice friction points through personality-informed collective decision-making.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "install:all": "cd client && npm install && cd ../server && npm install",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently -c \"cyan.bold,magenta.bold\" -n \"CLIENT,SERVER\" \"npm run dev:client\" \"npm run dev:server\"",
    "compose:config:stu": "docker compose --env-file deploy/compose/stu.env -f docker-compose.yml config",
    "compose:config:hms": "docker compose --env-file deploy/compose/hms.env -f docker-compose.yml config",
    "compose:config:elia": "docker compose --env-file deploy/compose/elia.env -f docker-compose.yml config",
    "compose:up:stu": "docker compose --env-file deploy/compose/stu.env -f docker-compose.yml up -d",
    "compose:up:hms": "docker compose --env-file deploy/compose/hms.env -f docker-compose.yml up -d",
    "compose:up:elia": "docker compose --env-file deploy/compose/elia.env -f docker-compose.yml up -d",
    "compose:down:stu": "docker compose --env-file deploy/compose/stu.env -f docker-compose.yml down --remove-orphans",
    "compose:down:hms": "docker compose --env-file deploy/compose/hms.env -f docker-compose.yml down --remove-orphans",
    "compose:down:elia": "docker compose --env-file deploy/compose/elia.env -f docker-compose.yml down --remove-orphans",
    "compose:ps:stu": "docker compose --env-file deploy/compose/stu.env -f docker-compose.yml ps",
    "compose:ps:hms": "docker compose --env-file deploy/compose/hms.env -f docker-compose.yml ps",
    "compose:ps:elia": "docker compose --env-file deploy/compose/elia.env -f docker-compose.yml ps",
    "compose:health:stu": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action health -EnvFile deploy/compose/stu.env",
    "compose:health:hms": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action health -EnvFile deploy/compose/hms.env",
    "compose:health:elia": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action health -EnvFile deploy/compose/elia.env",
    "compose:inspect:stu": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action inspect -EnvFile deploy/compose/stu.env",
    "compose:inspect:hms": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action inspect -EnvFile deploy/compose/hms.env",
    "compose:inspect:elia": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action inspect -EnvFile deploy/compose/elia.env",
    "compose:validate-isolation": "powershell -ExecutionPolicy Bypass -File scripts/compose-instance.ps1 -Action validate-isolation",
    "compose:verify-isolation": "powershell -ExecutionPolicy Bypass -File scripts/verify-isolation.ps1",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "deploy:test": "bash scripts/test-deploy-remote.sh",
    "deploy:smoke": "bash scripts/smoke-remote.sh",
    "deploy:smoke:test": "bash scripts/test-smoke-remote.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmatton/AAPR.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nmatton/AAPR/issues"
  },
  "homepage": "https://github.com/nmatton/AAPR#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
